{UTF-8}
Eligible Battery Supply=180
	~	
	~		|

Base Capacity Growth=12
	~	
	~		|

Base Investment=1
	~	
	~		|

Base Saving Emission=1.8
	~	
	~		|

Base Trust Building=0.12
	~	
	~		|

Battery Lifetime=6
	~	
	~		|

"Battery refurbishment capability (T2)"=0.85
	~	
	~	Original value = 0.55
		Technical Push = 0.85
	|

"Market demand stability (E2)"=MAX ( 0 , MIN ( 1 , ((0.35*"Consumer trust and acceptance (S1)"\
		) + (0.25*"Cost-efficiency and residual value (E3)"
	) + (0.2*"Certification and standardization protocols (R2)") + (0.2*"Community engagement (S3)"\
		)))  )
	~	
	~		|

"Policy incentives for second-life deployment (R1)"=0.85
	~	
	~	Nilai Asli 0.55
		
		Regulatory Push/Integrated = 0.85
	|

Capacity Decay Fraction=0.05
	~	
	~		|

Safety Incident Risk=MAX ( 0 , 1 - ((0.4*"SoH diagnostic accuracy (T1)") + (0.4*"Compliance with safety standards (T3)"\
		) + (0.2*"Digital traceability systems (R3)")) )
	~	
	~		|

Carbon Intensity Factor=0.7
	~	
	~		|

"Certification and standardization protocols (R2)"=0.9
	~	
	~	Original Value = 0.65
		
		Regulatory Push/Integrated = 0.9
	|

"Community engagement (S3)"=0.7
	~	
	~	Original value = 0.45
		Integrated pathway = 0.7
	|

"Compliance with safety standards (T3)"=0.6
	~	
	~	Original value = 0.6
		Technical Push = 0.85
	|

Comulative Emission Reduction= INTEG (Emission Reduction Rate,
		0)
	~	
	~		|

Trust Building rate=Base Trust Building * ("Certification and standardization protocols (R2)"\
		+"Community engagement (S3)"+"Compliance with safety standards (T3)"+"Digital traceability systems (R3)"\
		)/4
	~	
	~		|

"Cost-efficiency and residual value (E3)"=MAX ( 0 , MIN ( 1 , ((0.45*"Battery refurbishment capability (T2)"\
		) + (0.15*"Policy incentives for second-life deployment (R1)"
	) + (0.25*SLB Scale Economy) + (0.2*"Workforce skill availability (S2)") ))  )
	~	
	~		|

Trust Erosion=Safety Incident Risk*Trust Capital*Trust Erosion Sensitivity
	~	
	~		|

Trust Erosion Sensitivity=0.2
	~	
	~		|

"Digital traceability systems (R3)"=0.85
	~	
	~	Original Value = 0.5
		Regulatory push = 0.85
	|

"Workforce skill availability (S2)"=0.7
	~	
	~	Original value = 0.5
		Technical Push = 0.7
	|

Emission Reduction Potential=MAX ( 0 , MIN ( 1 , (0.4*"Lifecycle carbon intensity reduction (EN1)"\
		) + (0.3*"Energy efficiency of repurposed systems (EN3)"
	) + (0.3* SLB Scale Economy))  )
	~	
	~		|

Emission Reduction Rate=Emission Saving per Unit*SLB Deployment*Emission Reduction Potential
	~	
	~		|

Emission Saving per Unit=Base Saving Emission*Carbon Intensity Factor*"Energy efficiency of repurposed systems (EN3)"\
		*"Lifecycle carbon intensity reduction (EN1)"
	~	
	~		|

"Energy efficiency of repurposed systems (EN3)"=MAX ( 0 , MIN ( 1 , (0.5*"Battery refurbishment capability (T2)"\
		) + (0.25*"Workforce skill availability (S2)") + (0.25*"SoH diagnostic accuracy (T1)"\
		) )  )
	~	
	~		|

Trust building=Trust Building rate
	~	
	~		|

"Lifecycle carbon intensity reduction (EN1)"=MAX ( 0 , MIN ( 1 , (0.4*"SoH diagnostic accuracy (T1)"\
		) + (0.3*"Battery refurbishment capability (T2)") + (0.3*"Compliance with safety standards (T3)"\
		) )  )
	~	
	~		|

Trust Capital= INTEG (Trust building-Trust Erosion,
		0.5)
	~	
	~		|

"SoH diagnostic accuracy (T1)"=0.6
	~	
	~	Original Value = 0.6
		Technical Push = 0.9
	|

Scale Reference=500
	~	
	~		|

Deployment Rate=MIN ( Adoption Capacity , Eligible Battery Supply )  * Deployment Attractiveness
	~	
	~		|

"Investment flow and capital availability (E1)"=Base Investment*((0.4*"Policy incentives for second-life deployment (R1)"
	) + (0.3*"Certification and standardization protocols (R2)") + (0.3*"Consumer trust and acceptance (S1)"\
		))
	~	
	~		|

Capacity Formation Index=("Policy incentives for second-life deployment (R1)"+"Battery refurbishment capability (T2)"\
		+"Investment flow and capital availability (E1)"
	+"Digital traceability systems (R3)"
	+"Workforce skill availability (S2)")/5
	~	
	~		|

"Consumer trust and acceptance (S1)"=MAX ( 0 , MIN ( 1 , (0.35*"Compliance with safety standards (T3)"\
		) + (0.35*"Certification and standardization protocols (R2)") + (0.2*"Digital traceability systems (R3)"\
		) - (0.2*Safety Incident Risk) ) )
	~	
	~		|

Deployment Attractiveness=MAX ( 0 , MIN ( 1 , (0.35*"Market demand stability (E2)") +\
		 (0.25*"Consumer trust and acceptance (S1)") + (0.2*"Certification and standardization protocols (R2)"\
		) + (0.2*"Cost-efficiency and residual value (E3)") )  )
	~	
	~		|

SLB Scale Economy=MIN ( 1 , SLB Deployment/Scale Reference )
	~	
	~		|

Adoption Capacity= INTEG (Capacity Building-Capacity Decay,
		100)
	~	
	~		|

Capacity Building=Base Capacity Growth*Capacity Formation Index
	~	
	~		|

Capacity Decay=Adoption Capacity*Capacity Decay Fraction
	~	
	~		|

Retirement Rate=SLB Deployment/Battery Lifetime
	~	
	~		|

SLB Deployment= INTEG (Deployment Rate-Retirement Rate,
		50)
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

